# --- Envoi des demandes de réservation ---

# Clé API Resend utilisée par la fonction Vercel /api/reservation
RESEND_API_KEY="re_votre_cle_api"

# Adresse d'envoi utilisée comme expéditeur du mail
RESERVATION_MAIL_FROM="L'esquisse commune <no-respond@esquisse.aidhabitat.fr>"

# Destinataire des demandes
RESERVATION_MAIL_TO="contact@aidhabitat.fr"

# --- Configuration Stripe prévue pour une étape suivante ---

VITE_STRIPE_PUBLIC_KEY="pk_test_votre_cle_publique_stripe"
# STRIPE_SECRET_KEY="sk_test_votre_cle_secrete_stripe"
